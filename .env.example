# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Postgres URI for scripts/apply-migration-002.mjs (Dashboard → Settings → Database → URI)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Razorpay — get keys at https://dashboard.razorpay.com/app/keys
# Use Test Mode keys locally (rzp_test_...). Use Live keys on Vercel for production.
# NEXT_PUBLIC_RAZORPAY_KEY_ID must match RAZORPAY_KEY_ID (same Key ID, exposed to checkout UI).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Optional: Live keys for local claim-payment when testing Live Mode payments (Test Mode OFF in dashboard)
# RAZORPAY_LIVE_KEY_ID=rzp_live_...
# RAZORPAY_LIVE_KEY_SECRET=...

# Resend
RESEND_API_KEY=

# Anthropic — DM auto-annotation + judge scripts (scripts/auto-annotate-dms.mjs)
ANTHROPIC_API_KEY=

# Quiz nurture email cron (Vercel sends Authorization: Bearer CRON_SECRET)
CRON_SECRET=
NURTURE_UNSUBSCRIBE_SECRET=

# Optional: OpenAI for personalized AI match narratives (falls back to templates without it)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Optional: notify inbox when a new intern application arrives (defaults to hello@togetha.club)
# CAREERS_NOTIFY_EMAIL=hello@togetha.club

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_URL=

# Comma-separated emails that can access /admin (also set on Vercel Production)
ADMIN_EMAILS=hello@togetha.club

# Meta Pixel — Events Manager → Data sources → your pixel → Settings → Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=

# Jotform AI Agent (Sophie) — Publish → Chatbot → Copy Code, then paste the agent ID
# from cdn.jotfor.ms/agent/embedjs/<AGENT_ID>/embed.js into NEXT_PUBLIC_JOTFORM_AGENT_ID.
# When set, the full Sophie chatbot loads on the marketing site instead of the channel launcher.
NEXT_PUBLIC_JOTFORM_AGENT_ID=
