# Togetha MOBILE backend — environment variables
#
# SHARED-PROD setup (2026-07): the mobile app shares the website's production
# Supabase project. The real .env carries the website's variable names
# (NEXT_PUBLIC_*); edge functions read the canonical SUPABASE_* names first
# and fall back to the NEXT_PUBLIC_* aliases.

# Supabase (SHARED prod project — same as togetha.club website)
NEXT_PUBLIC_SUPABASE_URL=            # website-canonical name (used in .env)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=           # server/edge-function only, never ship in the app
SUPABASE_DB_URL=                     # direct Postgres URL (migrations run by hand)

# Mobile-canonical aliases (optional — set these OR the NEXT_PUBLIC_* ones)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Razorpay — .env holds LIVE website keys. NEVER use them in dev; the app
# stays payment-mocked (DENO_ENV=development + keys unset) until rzp_test_
# keys are provided. Live keys go only into production edge-function secrets.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=         # must equal RAZORPAY_KEY_ID (client copy)

# Anthropic (Tia concierge proxy)
ANTHROPIC_API_KEY=

# Website vars also present in the shared .env (not read by mobile functions):
# ADMIN_EMAILS, RESEND_API_KEY, NEXT_PUBLIC_APP_URL, NEXT_PUBLIC_SITE_URL,
# NEXT_PUBLIC_WHATSAPP_URL, NEXT_PUBLIC_META_PIXEL_ID
